# Hanya 2 secret yang diperlukan di .env
# Semua credential Supabase per-server disimpan di database lokal (SQLite)

# Discord bot token — dapatkan di https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# JWT secret untuk web dashboard authentication
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_jwt_secret_here
