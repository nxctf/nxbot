#!/usr/bin/env bash
# ============================================================
# nxbot — CLI Wrapper for NXBot Docker Services
# Inspired by nxctl CLI architecture
# ============================================================

set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_SOURCE" ]; do
    SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
COMPOSE_FILE="$SCRIPT_DIR/docker-compose.yml"
PROJECT_NAME="nxbot"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

PREFIX_INFO="${GREEN}[INFO]${NC}"
PREFIX_WARN="${YELLOW}[WARN]${NC}"
PREFIX_ERROR="${RED}[ERROR]${NC}"

# ---- Helpers ----

compose() {
    docker compose -f "$COMPOSE_FILE" -p "$PROJECT_NAME" "$@"
}

print_banner() {
    echo -e "${CYAN}${BOLD}"
    echo "  _   ___  ______       _   "
    echo " | \\ | \\ \\/ / __ ) ___ | |_ "
    echo " |  \\| |\\  /|  _ \\/ _ \\| __|"
    echo " | |\\  |/  \\| |_) | (_) | |_ "
    echo " |_| \\_/_/\\_\\____/ \\___/ \\__|"
    echo ""
    echo -e "${NC} Multi-Server Discord CTF Bot Platform"
    echo ""
}

usage() {
    print_banner
    echo -e "${BOLD}Usage:${NC} nxbot <command>"
    echo ""
    echo -e "${BOLD}Commands:${NC}"
    echo -e "  ${CYAN}install${NC}         Install nxbot system-wide + dependencies"
    echo -e "  ${CYAN}setup${NC}           Initialize database and first-time setup"
    echo -e "  ${CYAN}build${NC}           Build/rebuild Docker containers"
    echo -e "  ${CYAN}start${NC}           Start all services"
    echo -e "  ${CYAN}stop${NC}            Stop all services"
    echo -e "  ${CYAN}restart${NC}         Restart all services"
    echo -e "  ${CYAN}status${NC}          Show service status"
    echo -e "  ${CYAN}logs${NC} [service]  Tail logs (web-dashboard | discord-bot)"
    echo -e "  ${CYAN}credentials${NC}     Show admin login info"
    echo -e "  ${CYAN}reset-password${NC}  Change admin password via CLI"
    echo -e "  ${CYAN}update${NC}          Pull latest code & rebuild containers"
    echo ""
    echo -e "${BOLD}Examples:${NC}"
    echo "  nxbot install        # One-time setup after clone"
    echo "  nxbot start          # Start everything"
    echo "  nxbot update         # Git pull + rebuild"
    echo "  nxbot credentials    # Show admin username"
    echo ""
}

# ---- Commands ----

cmd_install() {
    print_banner
    echo -e "$PREFIX_INFO Installing NXBot..."

    # Make self executable
    chmod +x "$SCRIPT_DIR/nxbot"
    echo -e "$PREFIX_INFO Made nxbot executable"

    # Check dependencies
    if ! command -v docker &>/dev/null; then
        echo -e "$PREFIX_ERROR Docker is required. Install it first."
        exit 1
    fi
    echo -e "$PREFIX_INFO Docker found"

    if ! docker compose version &>/dev/null; then
        echo -e "$PREFIX_ERROR Docker Compose is required. Install it first."
        exit 1
    fi
    echo -e "$PREFIX_INFO Docker Compose found"

    # Install nxbot command system-wide
    local BIN_DIR="/usr/local/bin"
    if [ -w "$BIN_DIR" ]; then
        ln -sf "$SCRIPT_DIR/nxbot" "$BIN_DIR/nxbot"
        echo -e "$PREFIX_INFO Installed ${CYAN}nxbot${NC} to $BIN_DIR"
    else
        echo -e "$PREFIX_INFO Installing to $BIN_DIR (requires sudo)..."
        sudo ln -sf "$SCRIPT_DIR/nxbot" "$BIN_DIR/nxbot"
        echo -e "$PREFIX_INFO Installed ${CYAN}nxbot${NC} to $BIN_DIR"
    fi

    # Create data directory
    mkdir -p "$SCRIPT_DIR/data"

    # Run setup (init DB + .env)
    cmd_setup

    echo ""
    echo -e "$PREFIX_INFO ${GREEN}Installation complete!${NC}"
    echo -e "  Restart your shell or run: ${YELLOW}source ~/.bashrc${NC}"
    echo -e "  Then use: ${CYAN}nxbot start${NC} from anywhere"
    echo -e "  Or use:   ${CYAN}./nxbot start${NC} from the project directory"
    echo ""
}

cmd_credentials() {
    local DB_PATH="$SCRIPT_DIR/data/nxbot.db"

    if [ ! -f "$DB_PATH" ]; then
        echo -e "$PREFIX_ERROR No database found. Run ${CYAN}./nxbot setup${NC} first."
        exit 1
    fi

    if ! command -v sqlite3 &>/dev/null; then
        echo -e "$PREFIX_ERROR sqlite3 is required. Install it first."
        exit 1
    fi

    local is_setup
    is_setup=$(sqlite3 "$DB_PATH" "SELECT value FROM system_settings WHERE key = 'is_setup'" 2>/dev/null)

    if [ "$is_setup" != "true" ]; then
        echo -e "$PREFIX_WARN Setup not completed yet."
        echo -e "  Open ${CYAN}http://localhost:${PORT:-7000}${NC} to complete setup"
        exit 1
    fi

    local username
    username=$(sqlite3 "$DB_PATH" "SELECT value FROM system_settings WHERE key = 'admin_username'")

    echo ""
    echo -e "  ${BOLD}Admin Credentials${NC}"
    echo "  ─────────────────────────"
    echo -e "  Dashboard: ${CYAN}http://localhost:${PORT:-7000}${NC}"
    echo -e "  Username:  ${GREEN}$username${NC}"
    echo -e "  Password:  ${YELLOW}(hidden — use ./nxbot reset-password to change)${NC}"
    echo ""
}

cmd_reset_password() {
    local DB_PATH="$SCRIPT_DIR/data/nxbot.db"

    if [ ! -f "$DB_PATH" ]; then
        echo -e "$PREFIX_ERROR No database found. Run ${CYAN}./nxbot setup${NC} first."
        exit 1
    fi

    local is_setup
    is_setup=$(sqlite3 "$DB_PATH" "SELECT value FROM system_settings WHERE key = 'is_setup'" 2>/dev/null)

    if [ "$is_setup" != "true" ]; then
        echo -e "$PREFIX_ERROR Setup not completed yet. Complete CLI setup first."
        exit 1
    fi

    echo -e "$PREFIX_INFO Resetting admin password..."

    read -s -p "  Enter new password (min 6 chars): " password
    echo
    read -s -p "  Confirm new password: " password2
    echo

    if [ "$password" != "$password2" ]; then
        echo -e "$PREFIX_ERROR Passwords do not match."
        exit 1
    fi

    if [ ${#password} -lt 6 ]; then
        echo -e "$PREFIX_ERROR Password must be at least 6 characters."
        exit 1
    fi

    local SCRIPT="$SCRIPT_DIR/scripts/reset-password.js"
    if [ ! -f "$SCRIPT" ]; then
        echo -e "$PREFIX_ERROR reset-password.js not found."
        exit 1
    fi

    echo "$password" | compose run --rm -T nxbot node scripts/reset-password.js
    echo -e "$PREFIX_INFO Password updated successfully."
}

cmd_start() {
    echo -e "$PREFIX_INFO Starting all NXBot services..."
    compose up -d
    echo -e "$PREFIX_INFO All services started."
    echo -e "$PREFIX_INFO Web Dashboard: ${CYAN}http://localhost:${PORT:-7000}${NC}"

    # Show credential hint if setup done
    local DB_PATH="$SCRIPT_DIR/data/nxbot.db"
    if [ -f "$DB_PATH" ]; then
        local username
        username=$(sqlite3 "$DB_PATH" "SELECT value FROM system_settings WHERE key = 'admin_username'" 2>/dev/null)
        if [ -n "$username" ]; then
            echo -e "$PREFIX_INFO Login: ${GREEN}$username${NC}"
            echo -e "$PREFIX_INFO Forgot password? Run: ${CYAN}./nxbot reset-password${NC}"
        fi
    fi

    cmd_status
}

cmd_stop() {
    echo -e "$PREFIX_INFO Stopping all NXBot services..."
    compose down
    echo -e "$PREFIX_INFO All services stopped."
}

cmd_restart() {
    echo -e "$PREFIX_INFO Restarting all NXBot services..."
    cmd_stop
    cmd_start
}

cmd_status() {
    echo -e "${BOLD}NXBot Service Status${NC}"
    echo "─────────────────────────────────────"
    compose ps -a
}

cmd_logs() {
    local service="${1:-}"
    case "$service" in
        "")
            compose logs -f
            ;;
        *)
            compose logs -f "$service"
            ;;
    esac
}

cmd_build() {
    echo -e "$PREFIX_INFO Building NXBot containers..."
    compose build
    echo -e "$PREFIX_INFO Build complete."
}

cmd_update() {
    echo -e "$PREFIX_INFO Updating NXBot from repository..."

    if ! command -v git &>/dev/null; then
        echo -e "$PREFIX_ERROR git is required for update."
        exit 1
    fi

    # Stash any local changes, pull latest
    git -C "$SCRIPT_DIR" stash --quiet 2>/dev/null || true
    git -C "$SCRIPT_DIR" pull --rebase
    echo -e "$PREFIX_INFO Repository updated to latest version"

    # Re-make executable
    chmod +x "$SCRIPT_DIR/nxbot"
    echo -e "$PREFIX_INFO Made nxbot executable"

    # Re-install symlink (in case install target changed)
    local BIN_DIR="/usr/local/bin"
    if [ -L "$BIN_DIR/nxbot" ]; then
        if [ -w "$BIN_DIR" ]; then
            ln -sf "$SCRIPT_DIR/nxbot" "$BIN_DIR/nxbot"
        else
            sudo ln -sf "$SCRIPT_DIR/nxbot" "$BIN_DIR/nxbot"
        fi
        echo -e "$PREFIX_INFO Symlink refreshed"
    fi

    # Rebuild containers
    echo -e "$PREFIX_INFO Rebuilding containers..."
    compose build

    echo ""
    echo -e "$PREFIX_INFO ${GREEN}Update complete!${NC}"
    echo -e "  Run ${CYAN}nxbot start${NC} to restart services with the new code"
    echo ""
}

cmd_setup() {
    echo -e "$PREFIX_INFO Running first-time setup..."

    # Ensure data directory exists
    mkdir -p "$SCRIPT_DIR/data"

    # Check if sqlite3 is available
    if ! command -v sqlite3 &>/dev/null; then
        echo -e "$PREFIX_ERROR sqlite3 is required for setup. Install it first."
        exit 1
    fi

    local DB_PATH="$SCRIPT_DIR/data/nxbot.db"

    if [ -f "$DB_PATH" ]; then
        echo -e "$PREFIX_WARN Database already exists at $DB_PATH"
        read -p "Reset and recreate? (y/N): " -r confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            echo -e "$PREFIX_INFO Setup cancelled."
            return
        fi
        rm -f "$DB_PATH"
    fi

    # Initialize database from schema
    sqlite3 "$DB_PATH" < "$SCRIPT_DIR/db/schema.sql"
    echo -e "$PREFIX_INFO Database initialized at $DB_PATH"

    # Check .env
    if [ ! -f "$SCRIPT_DIR/.env" ]; then
        if [ -f "$SCRIPT_DIR/.env.example" ]; then
            cp "$SCRIPT_DIR/.env.example" "$SCRIPT_DIR/.env"
            echo -e "$PREFIX_WARN Created .env from .env.example — please edit it with your tokens."
        else
            echo -e "$PREFIX_ERROR No .env or .env.example found."
        fi
    else
        echo -e "$PREFIX_INFO .env file already exists."
    fi

    # Prompts for admin credentials
    echo ""
    echo -e "$PREFIX_INFO Configure Administrator Credentials"
    echo "  ──────────────────────────────────────────"

    local username=""
    while [ -z "$username" ] || [ ${#username} -lt 3 ]; do
        read -p "  Enter admin username (min 3 chars): " username
        if [ ${#username} -lt 3 ]; then
            echo -e "  $PREFIX_ERROR Username is too short."
        fi
    done

    local password=""
    local password_confirm=""
    while [ -z "$password" ] || [ ${#password} -lt 6 ] || [ "$password" != "$password_confirm" ]; do
        read -s -p "  Enter admin password (min 6 chars): " password
        echo
        read -s -p "  Confirm admin password: " password_confirm
        echo
        if [ ${#password} -lt 6 ]; then
            echo -e "  $PREFIX_ERROR Password must be at least 6 characters."
        elif [ "$password" != "$password_confirm" ]; then
            echo -e "  $PREFIX_ERROR Passwords do not match."
        fi
    done

    # Run setup-credentials node script
    local SETUP_SCRIPT="$SCRIPT_DIR/scripts/setup-credentials.js"
    if [ ! -f "$SETUP_SCRIPT" ]; then
        echo -e "$PREFIX_ERROR setup-credentials.js not found."
        exit 1
    fi

    # Pass username and password via stdin
    echo -e "${username}\n${password}" | compose run --rm -T nxbot node scripts/setup-credentials.js

    echo ""
    echo -e "$PREFIX_INFO Setup complete! Next steps:"
    echo -e "  1. Edit ${CYAN}.env${NC} with your DISCORD_BOT_TOKEN and JWT_SECRET"
    echo -e "  2. Run ${CYAN}./nxbot start${NC}"
    echo -e "  3. Open ${CYAN}http://localhost:${PORT:-7000}${NC} and log in with your credentials"
    echo -e ""
    echo -e "  To see admin username, run: ${CYAN}./nxbot credentials${NC}"
    echo -e "  To reset password, run: ${CYAN}./nxbot reset-password${NC}"
    echo ""
}

# ---- Main ----

main() {
    local cmd="${1:-}"

    case "$cmd" in
        install)        cmd_install ;;
        credentials)     cmd_credentials ;;
        reset-password)  cmd_reset_password ;;
        start)           cmd_start ;;
        stop)            cmd_stop ;;
        restart)         cmd_restart ;;
        status)          cmd_status ;;
        logs)            shift; cmd_logs "$@" ;;
        build)           cmd_build ;;
        setup)           cmd_setup ;;
        update)          cmd_update ;;
        help|--help|-h|"")
            usage
            ;;
        *)
            echo -e "$PREFIX_ERROR Unknown command: $cmd"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
